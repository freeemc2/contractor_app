class User(db.Model):
    """Contractor or business user"""
    id = db.Column(db.Integer, primary_key=True)
    email = db.Column(db.String(255), unique=True, nullable=False, index=True)
    password_hash = db.Column(db.String(255), nullable=False)
    company_name = db.Column(db.String(255))
    trade = db.Column(db.String(100))  # electrician, plumber, contractor
    service_area = db.Column(db.String(255))  # cities/zip codes
    is_admin = db.Column(db.Boolean, default=False)
    trial_start = db.Column(db.DateTime, default=datetime.utcnow)
    stripe_customer_id = db.Column(db.String(255))
    stripe_subscription_id = db.Column(db.String(255))
    subscription_status = db.Column(db.String(50), default="trial")
    created_at = db.Column(db.DateTime, default=datetime.utcnow, index=True)
    
    @property
    def trial_active(self):
        return datetime.utcnow() < self.trial_start + timedelta(days=3)
    
    @property
    def has_access(self):
        return self.trial_active or self.subscription_status == "active"


class Lead(db.Model):
    """Warm lead from any source"""
    __tablename__ = "leads"
    id = db.Column(db.Integer, primary_key=True)
    
    # Source info
    source = db.Column(db.String(100), index=True)  # reddit, facebook, craigslist, duckduckgo
    source_url = db.Column(db.String(1000))
    
    # Lead content
    keyword = db.Column(db.String(200), index=True)  # electrician, plumber, contractor
    title = db.Column(db.String(500))
    description = db.Column(db.Text)
    post_text = db.Column(db.Text)  # Full original post
    
    # Contact info (extracted by AI)
    customer_name = db.Column(db.String(255))
    phone = db.Column(db.String(50))
    email = db.Column(db.String(255))
    
    # Location
    location = db.Column(db.String(255), index=True)
    city = db.Column(db.String(200))
    state = db.Column(db.String(10))
    zip_code = db.Column(db.String(10))
    lat = db.Column(db.Float, index=True)
    lon = db.Column(db.Float, index=True)
    
    # Meta
    urgency = db.Column(db.String(50))  # ASAP, this week, flexible
    quality_score = db.Column(db.Float)  # AI-determined quality (0-1)
    active = db.Column(db.Boolean, default=True, index=True)
    assigned_to = db.Column(db.Integer, db.ForeignKey("user.id"), nullable=True)
    status = db.Column(db.String(50), default="new", index=True)  # new, assigned, contacted, closed
    response_status = db.Column(db.String(50), default="pending", index=True)  # pending, responded, qualified, deposit_sent, deposit_paid
    review_status = db.Column(db.String(20), default="pending", index=True)  # pending, approved, rejected
    
    # Payment/Deposit tracking
    deposit_amount = db.Column(db.Float)
    deposit_paid_at = db.Column(db.DateTime)
    deposit_payment_link = db.Column(db.String(1000))
    stripe_session_id = db.Column(db.String(255))
    
    # Timestamps
    posted_at = db.Column(db.DateTime)  # When customer posted
    scraped_at = db.Column(db.DateTime, default=datetime.utcnow, index=True)
    assigned_at = db.Column(db.DateTime)
    
    # AI collation
    ai_processed = db.Column(db.Boolean, default=False)
    ai_extracted_data = db.Column(db.JSON)  # Full AI extraction results


class ScrapeJob(db.Model):
    """Job queue for distributed agents"""
    __tablename__ = "scrape_jobs"
    id = db.Column(db.Integer, primary_key=True)
    
    keyword = db.Column(db.String(200), index=True)
    location = db.Column(db.String(255))
    source = db.Column(db.String(100))  # reddit, craigslist, facebook, duckduckgo
    
