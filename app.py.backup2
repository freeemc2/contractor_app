@app.route("/health")
def health():
    return jsonify({
        "status": "ok",
        "platform": "contractor-lead-finder",
        "agents": Agent.query.filter_by(status="active").count(),
        "pending_jobs": ScrapeJob.query.filter_by(status="pending").count(),
        "total_leads": Lead.query.filter_by(active=True).count(),
    })


